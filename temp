apiVersion: v1
kind: Namespace
metadata:
  name: openshift-logging
  labels:
    openshift.io/cluster-monitoring: "true"
---
apiVersion: policy.open-cluster-management.io/v1
kind: Policy
metadata:
  name: policy-openshift-logging
  namespace: open-cluster-management-policies
spec:
  remediationAction: enforce
  disabled: false
  policy-templates:
    - objectDefinition:
        apiVersion: policy.open-cluster-management.io/v1beta1
        kind: OperatorPolicy
        metadata:
          name: openshift-logging-operator
        spec:
          remediationAction: enforce
          severity: high
          complianceType: musthave
          upgradeApproval: Automatic
          operatorGroup:
            name: cluster-logging
            namespace: openshift-logging
            targetNamespaces:
              - openshift-logging
          subscription:
            name: cluster-logging
            namespace: openshift-logging
            channel: stable-6.2
            source: redhat-operators
            sourceNamespace: openshift-marketplace
---

for node in $(oc get nodes -l node-role.kubernetes.io/physical-worker -o jsonpath='{.items[*].metadata.name}'); do count=$(oc debug node/$node -- chroot /host bash -c 'grep -c "^Slave Interface:" /proc/net/bonding/bond0 2>/dev/null || echo 0' 2>/dev/null | tr -d '\r\n '); echo "$node: $count"; done
